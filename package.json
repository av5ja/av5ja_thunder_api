{
  "name": "thunder_api",
  "version": "7.0.6",
  "description": "SplatNet3から取得したJSONをパースしてSplatNet2形式などの扱いやすいフォーマットに変換してくれるAPIです",
  "author": "@tkgstrator",
  "private": true,
  "license": "MIT",
  "scripts": {
    "dev": "wrangler dev --test-scheduled --port 18787",
    "start": "bun dist/index.js",
    "postinstall": "prisma generate",
    "deploy": "bunx wrangler deploy --env production --minify src/index.ts",
    "deploy:dev": "bunx wrangler deploy --env development --minify src/index.ts",
    "db:generate": "prisma generate",
    "db:diff": "prisma migrate diff --from-empty --to-schema prisma/schema.prisma --script"
  },
  "dependencies": {
    "@prisma/adapter-d1": "^7",
    "@prisma/client": "^7",
    "@scalar/hono-api-reference": "^0.11.9",
    "dayjs": "^1.11.21",
    "hono": "^4.12.30",
    "lodash": "^4.18.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cloudflare/workers-types": "^5.20260714.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@hono/zod-openapi": "^1.5.0",
    "@types/bun": "^1.3.14",
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.1.1",
    "commitlint": "^21.2.1",
    "prisma": "^7",
    "rimraf": "^6.1.3",
    "wrangler": "4.110.0"
  },
  "module": "index.ts",
  "type": "module",
  "peerDependencies": {
    "typescript": "^7.0.2"
  }
}
